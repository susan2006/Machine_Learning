import pandas as pd
import math
import copy

# 1. Load dataset
df = pd.read_csv("studentmarks.csv")

# Remove "S NO" if present
if "S NO" in df.columns:
    df = df.drop(columns=["S NO"])

# Convert to list of lists
X = df.values.tolist()
attributes = list(df.columns[:-1])  # All columns except target
target_index = len(df.columns) - 1

class Node:
    def __init__(self):
        self.value = None
        self.decision = None
        self.childs = []

def findEntropy(data, rows):
    yes = no = 0
    ans = -1
    entropy = 0
    for i in rows:
        if data[i][target_index] == 'Y':
            yes += 1
        else:
            no += 1
    x = yes / (yes + no)
    y = no / (yes + no)
    if x != 0 and y != 0:
        entropy = -1 * (x * math.log2(x) + y * math.log2(y))
    if x == 1:
        ans = 1
    if y == 1:
        ans = 0
    return entropy, ans

def findMaxGain(data, rows, columns):
    maxGain = 0
    retidx = -1
    entropy, ans = findEntropy(data, rows)

    print(f"\nCurrent Set Entropy = {entropy:.4f}")
    if entropy == 0:
        return maxGain, retidx, ans

    print("Attribute Information Gains:")
    for j in columns:
        mydict = {}
        for i in rows:
            key = data[i][j]
            mydict[key] = mydict.get(key, 0) + 1

        weighted_entropy_sum = 0
        for key in mydict:
            yes = no = 0
            for k in rows:
                if data[k][j] == key:
                    if data[k][target_index] == 'Y':
                        yes += 1
                    else:
                        no += 1
            x = yes / (yes + no)
            y = no / (yes + no)
            sub_entropy = 0
            if x != 0 and y != 0:
                sub_entropy = -1 * (x * math.log2(x) + y * math.log2(y))
            weighted_entropy_sum += (mydict[key] / len(rows)) * sub_entropy

        info_gain = entropy - weighted_entropy_sum
        print(f"  {attributes[j]}: IG = {info_gain:.4f} | Weighted Entropy = {weighted_entropy_sum:.4f}")

        if info_gain > maxGain:
            maxGain = info_gain
            retidx = j

    return maxGain, retidx, ans

def buildTree(data, rows, columns):
    maxGain, idx, ans = findMaxGain(data, rows, columns)
    root = Node()

    if maxGain == 0:
        root.value = 'Y' if ans == 1 else 'N'
        return root

    root.value = attributes[idx]
    mydict = {}
    for i in rows:
        key = data[i][idx]
        mydict[key] = mydict.get(key, 0) + 1

    newcolumns = copy.deepcopy(columns)
    newcolumns.remove(idx)

    for key in mydict:
        newrows = [i for i in rows if data[i][idx] == key]
        temp = buildTree(data, newrows, newcolumns)
        temp.decision = key
        root.childs.append(temp)

    return root

def traverse(root, depth=0):
    prefix = "    " * depth
    if root.decision is not None:
        print(f"{prefix}[{root.decision}] -> {root.value}")
    else:
        print(f"{prefix}{root.value}")
    for child in root.childs:
        traverse(child, depth + 1)

# Prediction using the decision tree
def predict(root, sample):
    if not root.childs:
        return root.value  # Y or N

    attr_index = attributes.index(root.value)
    for child in root.childs:
        if sample[attr_index] == child.decision:
            return predict(child, sample)
    return None

def calculate():
    rows = list(range(len(X)))
    columns = list(range(len(attributes)))
    root = buildTree(X, rows, columns)
    root.decision = "Start"

    print("\n--- Decision Tree Structure ---")
    traverse(root)

    # Test with sample input
    print("\n--- Test Prediction ---")
    sample_input = []
    for attr in attributes:
        val = input(f"Enter value for {attr}: ")
        sample_input.append(val)

    prediction = predict(root, sample_input)
    print(f"\nPrediction for {sample_input} => {prediction}")

calculate()
